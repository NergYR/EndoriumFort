# ─── EndoriumFort production environment ───────────────────────────────────
# Copy to .env.prod and adapt values before deployment.

# Use an immutable release tag in production.
DOCKER_IMAGE=nergyr/endoriumfort
DOCKER_TAG=1.0.3

# Public ports exposed by the host.
EF_HTTP_PORT=80
EF_HTTPS_PORT=443

# Container timezone.
TZ=Europe/Paris

# ACME / Let's Encrypt (set ACME_ENABLED=1 for automatic certificates).
ACME_ENABLED=0
ACME_DOMAIN=example.com
ACME_EMAIL=admin@example.com

# Relay control-plane runtime (set a strong secret to enable enrollment).
ENDORIUMFORT_RELAY_ENROLL_SECRET=
ENDORIUMFORT_RELAY_CERT_REQUIRED=true
ENDORIUMFORT_RELAY_CERT_TTL_SECONDS=2592000
ENDORIUMFORT_RELAY_ENROLL_TOKEN_TTL_SECONDS=600
ENDORIUMFORT_RELAY_TOKEN_TTL_SECONDS=86400
ENDORIUMFORT_RELAY_HEARTBEAT_STALE_SECONDS=90
